# redtreat Content-Engine – Secrets (Kopie als ".env" speichern, NIE teilen/committen)

# Welcher Bild-Generator? gemini | cloudflare | huggingface
IMAGE_PROVIDER=gemini

# --- Google AI Studio (empfohlen, gratis) ---
# Schlüssel holen: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Alternative: Cloudflare Workers AI (gratis-Kontingent) ---
# CF_ACCOUNT_ID=
# CF_API_TOKEN=

# --- Alternative: Hugging Face (gratis) ---
# HF_TOKEN=
